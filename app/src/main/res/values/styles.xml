<resources>
    <style name="LauncherTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowFullscreen">true</item>
        <!-- Moonlight now moves decoding to a persistent background Surface
             during handoff, so this window can stay opaque and avoid partial
             redraw artifacts on Android TV compositors. -->
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowBackground">#05060A</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:colorAccent">#7C4DFF</item>
        <item name="android:navigationBarColor">#05060A</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
